{
  "name": "@imput/cobalt-desktop",
  "version": "1.0.14",
  "description": "Downie-like macOS media downloader powered by Cobalt Core",
  "main": "dist-electron/main/electron-launcher.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/fix-isolated-vm.mjs && electron-builder",
    "postinstall": "node scripts/fix-isolated-vm.mjs"
  },
  "dependencies": {
    "@datastructures-js/priority-queue": "^6.3.5",
    "@imput/psl": "^2.0.4",
    "@imput/version-info": "workspace:^",
    "content-disposition-header": "0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "ffmpeg-static": "^5.3.0",
    "hls-parser": "^0.16.0",
    "ipaddr.js": "2.3.0",
    "isolated-vm": "^6.0.2",
    "mime": "^4.1.0",
    "nanoid": "^5.1.6",
    "set-cookie-parser": "2.7.2",
    "undici": "^6.24.1",
    "url-pattern": "1.0.3",
    "@bufbuild/protobuf": "^2.2.5",
    "meriyah": "^6.1.4",
    "youtubei.js": "17.0.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tabler/icons-svelte": "^3.6.0",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "svelte": "^5.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.cobalt.app",
    "productName": "Cobalt",
    "electronVersion": "31.3.0",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "npmRebuild": false,
    "includeSubNodeModules": true,
    "afterPack": "./scripts/electron-builder-after-pack.cjs",
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**/*",
      "**/node_modules/isolated-vm/**/*",
      "**/node_modules/node-gyp-build/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "identity": "A3D0D2F6AB588511D0156428A74F1D9DD37C8144",
      "target": [
        "dmg"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
