# cobalt API — Environment Variables
# Copy this file to .env and fill in the values you need.
# See docs/api-env-variables.md for detailed documentation.

# --- Core ---
API_URL=http://localhost:9000          # Public-facing URL of this instance
API_PORT=9000                          # Port to listen on
API_LISTEN_ADDRESS=                    # Optional: bind to specific address (default: all interfaces)

# --- CORS ---
CORS_WILDCARD=1                        # Allow all origins (set to 0 to disable)
# CORS_URL=https://your-frontend.com   # Restrict to specific origin when CORS_WILDCARD=0

# --- Rate Limiting ---
RATELIMIT_WINDOW=60                    # Window in seconds
RATELIMIT_MAX=20                       # Max requests per window (per IP)
TUNNEL_RATELIMIT_WINDOW=60             # Tunnel rate limit window
TUNNEL_RATELIMIT_MAX=40                # Max tunnel requests per window
SESSION_RATELIMIT_WINDOW=60            # Session creation rate limit window
SESSION_RATELIMIT_MAX=10               # Max session creations per window

# --- Limits ---
DURATION_LIMIT=10800                   # Max video duration in seconds (default 3h)
TUNNEL_LIFESPAN=90                     # How long tunnel URLs remain valid (seconds)

# --- Authentication & Security ---
# JWT_SECRET=                           # Required for session auth (min 16 chars)
JWT_EXPIRY=120                         # JWT token expiry in seconds
API_AUTH_REQUIRED=0                    # Require authentication for all requests (set to 1)
API_KEY_URL=                           # URL to fetch API keys from

# --- Turnstile (uses Cloudflare Turnstile for anti-bot) ---
# TURNSTILE_SITEKEY=                   # Cloudflare Turnstile site key
# TURNSTILE_SECRET=                    # Cloudflare Turnstile secret

# --- Redis (required for multi-instance, optional for single) ---
# API_REDIS_URL=redis://localhost:6379
API_INSTANCE_COUNT=1                   # Number of API instances (>=2 requires Redis)

# --- YouTube ---
# CUSTOM_INNERTUBE_CLIENT=             # Custom YouTube InnerTube client (e.g. WEB, ANDROID, IOS)
# YOUTUBE_SESSION_SERVER=             # External YouTube session server URL
# YOUTUBE_SESSION_INNERTUBE_CLIENT=   # Innertube client for session server
YOUTUBE_ALLOW_BETTER_AUDIO=1           # Allow high quality YouTube audio
# YOUTUBE_PLAYER_ID=                   # Comma-separated list of YouTube player IDs

# --- Processing ---
PROCESSING_PRIORITY=                   # Niceness value for ffmpeg child processes (Linux only)
DISABLED_SERVICES=                     # Comma-separated services to disable (e.g. bilibili,facebook)
FORCE_LOCAL_PROCESSING=never           # never | session | always
ENABLE_DEPRECATED_YOUTUBE_HLS=never    # never | key | always

# --- Networking ---
FREEBIND_CIDR=                         # Linux only: CIDR range for IP binding
HTTP_PROXY=                            # HTTP proxy for outbound requests
HTTPS_PROXY=                           # HTTPS proxy for outbound requests
NO_PROXY=                              # Hosts to bypass proxy

# --- Cookies (for authenticated access to services) ---
# COOKIE_PATH=./cookies.json

# --- Dynamic Configuration ---
# API_ENV_FILE=                        # Path or URL to a file for live env reloading
